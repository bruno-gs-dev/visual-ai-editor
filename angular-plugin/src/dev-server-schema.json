{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Angular Dev Server Builder with data-ai-source",
  "description": "Extends @angular-devkit/build-angular:dev-server with automatic data-ai-source injection",
  "type": "object",
  "properties": {
    "browserTarget": {
      "type": "string",
      "description": "Target to serve"
    },
    "port": {
      "type": "number",
      "description": "Port to listen on"
    }
  },
  "additionalProperties": true,
  "required": ["browserTarget"]
}
