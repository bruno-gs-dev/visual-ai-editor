{
  "name": "visual-ai-editor",
  "version": "1.7.4",
  "description": "AI-powered visual HTML editor with selection tools, design-system enforcement, and surgical source patching. Works with any OpenAI-compatible LLM provider, including local ones like Ollama.",
  "main": "dist/ai-editor.js",
  "module": "dist/ai-editor.esm.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/ai-editor.esm.js",
      "require": "./dist/ai-editor.js",
      "default": "./dist/ai-editor.js"
    },
    "./server": {
      "types": "./types/server.d.ts",
      "require": "./server/index.js",
      "default": "./server/index.js"
    },
    "./server.js": "./server/server.js",
    "./dist/ai-editor.css": "./dist/ai-editor.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/",
    "server/",
    "templates/",
    "docs/",
    "!docs/safe-guard/",
    "!docs/gifs/",
    "bin/",
    "lib/",
    "types/",
    "scripts/postinstall.js",
    "examples/",
    "demo/",
    "README.md",
    "CHANGELOG.md"
  ],
  "bin": {
    "visual-ai-editor": "bin/cli.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node scripts/build.js --watch",
    "postinstall": "node scripts/postinstall.js",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "ai",
    "editor",
    "html",
    "visual",
    "groq",
    "openai",
    "opencode",
    "anthropic",
    "ollama",
    "design-system",
    "layout",
    "component"
  ],
  "author": "bruno-gs-dev",
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "marked": "^18.0.6",
    "playwright": "^1.61.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bruno-gs-dev/visual-ai-editor.git"
  }
}
