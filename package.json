{
  "name": "visual-ai-editor",
  "version": "1.1.1",
  "description": "AI-powered visual HTML editor with selection tools and Groq API integration",
  "main": "dist/ai-editor.js",
  "module": "dist/ai-editor.esm.js",
  "exports": {
    ".": {
      "import": "./dist/ai-editor.esm.js",
      "require": "./dist/ai-editor.js",
      "default": "./dist/ai-editor.js"
    },
    "./server": {
      "require": "./server/index.js",
      "default": "./server/index.js"
    },
    "./server.js": "./server/server.js",
    "./dist/ai-editor.css": "./dist/ai-editor.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/",
    "server/",
    "examples/",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node scripts/build.js --watch"
  },
  "keywords": [
    "ai",
    "editor",
    "html",
    "visual",
    "groq",
    "design-system",
    "layout",
    "component"
  ],
  "author": "bruno-gs-dev",
  "license": "MIT",
  "sideEffects": ["*.css"],
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "peerDependencies": {
    "marked": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "marked": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bruno-gs-dev/visual-ai-editor.git"
  }
}
