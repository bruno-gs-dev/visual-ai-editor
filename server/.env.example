# Preferred (provider-agnostic — any OpenAI-compatible API):
AI_API_KEY=your_key_here
#AI_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
#AI_MODEL=llama-3.3-70b-versatile
#PORT=3000

# OpenCode Zen (free models available — needs API key from https://opencode.ai):
#AI_ENDPOINT=https://opencode.ai/zen/v1/chat/completions
#AI_MODEL=deepseek-v4-flash-free

# Anthropic (Claude) — uses the Anthropic Messages API natively:
#AI_ENDPOINT=https://api.anthropic.com/v1/messages
#AI_MODEL=claude-sonnet-4-20250514

# Local providers (no API key needed):
#AI_ENDPOINT=http://localhost:11434/v1/chat/completions   # Ollama
#AI_ENDPOINT=http://localhost:1234/v1/chat/completions    # LM Studio

# Legacy (still honored):
#GROQ_API_KEY=your_groq_api_key_here
#GROQ_MODEL=llama-3.3-70b-versatile

# Tip: use `npx visual-ai-editor config` for interactive setup instead of editing this file.
