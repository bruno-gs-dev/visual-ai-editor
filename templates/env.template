# visual-ai-editor — configuration
#
# 1. Paste your AI provider API key below (the only required step).
# 2. Run `npx visual-ai-editor start` again.
#
# Any OpenAI-compatible provider works. Groq's free tier is the fastest
# way to try it: https://console.groq.com
AI_API_KEY=

# ---------------------------------------------------------------------------
# Everything below is optional — defaults shown. Uncomment to override.
# ---------------------------------------------------------------------------

# Provider endpoint (default: Groq)
#AI_ENDPOINT=https://api.groq.com/openai/v1/chat/completions

# Model name understood by the endpoint (default: llama-3.3-70b-versatile)
#AI_MODEL=llama-3.3-70b-versatile

# Local providers — no API key needed, just uncomment one:
#AI_ENDPOINT=http://localhost:11434/v1/chat/completions
#AI_MODEL=llama3.2
# (Ollama — pull the model first: `ollama pull llama3.2`)
#AI_ENDPOINT=http://localhost:1234/v1/chat/completions
# (LM Studio — use whatever model you have loaded)

# Server port (default: 3000)
#PORT=3000
